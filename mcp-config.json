{
  "mcpServers": {
    "docs2mcp": {
      "command": "python3",
      "args": [
        "-m",
        "http.client",
        "--port",
        "5000"
      ],
      "env": {
        "MCP_HOST": "localhost",
        "MCP_PORT": "5000"
      },
      "description": "Docs2MCP - Documentation Crawler for AI Development"
    }
  }
}
